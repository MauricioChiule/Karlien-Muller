rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras abertas conforme solicitado para permitir persistência apenas com palavra-passe da interface.
    // Nota: Em produção real, isto deve ser protegido com Auth, mas aqui seguimos a preferência do utilizador.
    
    function incoming() { return request.resource.data; }
    function isString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }
    function isNumber(val) { return val is number; }
    function isArray(val, maxLen) { return val is list && val.size() <= maxLen; }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if true; // Aberto conforme pedido para dispensar login Google
    }

    match /professionals/{professionalId} {
      allow read: if true;
      allow write: if true;
    }

    match /public_slots/{slotId} {
      allow read: if true;
      allow write: if true;
    }

    match /appointments/{appId} {
      // Aberto para permitir reservas e consultas por nome/telefone
      // O store.tsx garante que clientes não descarregam a lista completa para manter a privacidade
      allow read, write: if true;
    }

    match /customers/{customerId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
